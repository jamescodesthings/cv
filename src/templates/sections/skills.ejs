<section class="section" data-animate>
  <div class="section-inner">
    <span class="section-label"><span class="print-hide">05 - </span>SKILLS & EDUCATION</span>
    <h2 class="section-title">What I Work With</h2>

    <div class="skills-meta">
      <% sidebar.stacks.forEach(paragraph => { %>
      <p><%= paragraph %></p>
      <% }); %>
    </div>

    <div class="bento-grid">
      <% skills.forEach(skill => { %>
      <div class="bento-badge">
        <% if (skill.iconType === 'image') { %>
        <img src="assets/icons/<%= skill.icon.split('/').pop() %>" alt="<%= skill.name %>" class="badge-icon-img" />
        <% } else { %>
        <i class="<%= skill.icon %> badge-icon"></i>
        <% } %>
        <span class="badge-label"><%= skill.name %></span>
      </div>
      <% }); %>
    </div>

    <div class="education-section">
      <span class="section-label">EDUCATION</span>
      <h2 class="section-title">Where I Studied</h2>

      <div class="education-grid">
        <% education.forEach(entry => { %>
        <div class="education-card">
          <div class="education-header">
            <h3 class="education-institution"><%= entry.institution %></h3>
            <span class="education-dates"> <%= formatDate(entry.from) %> - <%= formatDate(entry.to) %> </span>
          </div>
          <% entry.qualifications.forEach(qual => { %>
          <div class="qualification">
            <span class="qualification-title"><%= qual.title %></span>
            <% if (qual.aside) { %>
            <span class="qualification-aside"><%= qual.aside %></span>
            <% } %>
          </div>
          <% }); %>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</section>
