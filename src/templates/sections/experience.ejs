<section class="section" data-animate>
  <div class="section-inner">
    <span class="section-label"><span class="print-hide">02 - </span>EXPERIENCE</span>
    <h2 class="section-title">Where I've Worked</h2>

    <div class="profile-summary">
      <% profile.forEach(paragraph => { %>
      <p><%= paragraph %></p>
      <% }); %>
    </div>

    <div class="experience-list">
      <% experience.forEach((job, index) => { %>
      <article class="experience-entry">
        <div class="experience-header">
          <div class="experience-meta">
            <span class="experience-number"><%= String(index + 1).padStart(2, '0') %></span>
            <span class="experience-dates">
              <%= formatDate(job.from) %> - <%= job.to ? formatDate(job.to) : 'Present' %>
            </span>
          </div>
          <h3 class="experience-employer"><%= job.employer %></h3>
          <p class="experience-summary"><%= job.summary %></p>
        </div>

        <% if (job.tech && job.tech.length > 0) { %>
        <div class="tech-badges">
          <% job.tech.forEach(tech => { %>
          <span class="badge">
            <% if (tech.iconType === 'image') { %>
            <img src="assets/icons/<%= tech.icon.split('/').pop() %>" alt="<%= tech.label %>" class="badge-icon-img" />
            <% } else { %>
            <i class="<%= tech.icon %> badge-icon"></i>
            <% } %> <%= tech.label %>
          </span>
          <% }); %>
        </div>
        <% } %> <% if (job.detail) { %>
        <div class="experience-detail <%= index > 0 ? 'print-hide' : '' %>">
          <% job.detail.forEach(group => { %>
          <div class="detail-group">
            <% group.forEach(paragraph => { %>
            <p><%= paragraph %></p>
            <% }); %>
          </div>
          <% }); %>
        </div>
        <% } %>
      </article>
      <% }); %>
    </div>
  </div>
</section>
