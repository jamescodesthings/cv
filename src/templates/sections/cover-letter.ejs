<section class="section" data-animate>
  <div class="section-inner">
    <span class="section-label print-hide"><span class="print-hide">01 - </span>ABOUT</span>
    <div class="about-grid">
      <div class="about-sidebar">
        <div class="avatar">
          <img
            src="assets/profile.png"
            alt="James Macmillan"
            class="avatar-img"
            width="120"
            height="120"
            loading="lazy"
          />
        </div>
        <div class="contact-card">
          <h3 class="label display lg">cOnTaCt</h3>
          <ul class="contact-list">
            <li>
              <span class="contact-label">Phone</span>
              <a href="tel:<%= sidebar.contact.phone %>"><%= sidebar.contact.phone %></a>
            </li>
            <li>
              <span class="contact-label">Email</span>
              <a href="mailto:<%= sidebar.contact.email %>"><%= sidebar.contact.email %></a>
            </li>
            <li>
              <span class="contact-label">Location</span>
              <span><%= sidebar.contact.address %></span>
            </li>
            <li>
              <span class="contact-label">Availability</span>
              <div class="availability">
                <span class="availability-dot print-hide"></span>
                <span><%= sidebar.availability %></span>
              </div>
            </li>
          </ul>
          <div class="contact-socials print-hide">
            <a href="<%= sidebar.socials.linkedin %>" target="_blank" rel="noopener noreferrer" class="social-link"
              >LinkedIn</a
            >
            <a href="<%= sidebar.socials.whatsapp.url %>" target="_blank" rel="noopener noreferrer" class="social-link"
              >WhatsApp</a
            >
          </div>
        </div>
      </div>
      <div class="about-main">
        <h2 class="section-title">Cover Letter</h2>
        <div class="prose">
          <% const content = coverLetter.seeking ? coverLetter.content : coverLetter.notSeekingContent; %> <%
          content.forEach(paragraph => { %>
          <p><%= paragraph %></p>
          <% }); %>
          <p class="signature"><%= coverLetter.signature %></p>
        </div>
      </div>
    </div>
  </div>
</section>
